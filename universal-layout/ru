    include "ru(typewriter)"
    name[Group1]= "Russian (GOST 14289-88)";

    key <TLDE> { [  backslash, asterisk,   asciitilde, section ] };
    key <AE01> { [  parenleft,        1,         less, guillemotleft ] };
    key <AE02> { [ parenright,        2,           at, guillemotright ] };
